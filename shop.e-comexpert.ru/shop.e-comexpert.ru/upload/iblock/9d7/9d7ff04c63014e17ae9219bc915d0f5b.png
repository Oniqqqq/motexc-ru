<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 400">
  <defs>
    <linearGradient id="banner" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" style="stop-color:#E84D4D;stop-opacity:1"/>
      <stop offset="100%" style="stop-color:#1a2340;stop-opacity:1"/>
    </linearGradient>
  </defs>
  <rect width="1200" height="400" fill="url(#banner)"/>
  <text x="120" y="160" font-family="Arial,sans-serif" font-size="52" font-weight="bold" fill="#fff">Скидки до 40%</text>
  <text x="120" y="220" font-family="Arial,sans-serif" font-size="28" fill="rgba(255,255,255,0.85)">на моторные масла и фильтры</text>
  <rect x="120" y="260" width="200" height="56" rx="8" fill="#fff"/>
  <text x="220" y="296" font-family="Arial,sans-serif" font-size="20" font-weight="bold" fill="#E84D4D" text-anchor="middle">Смотреть акции</text>
</svg>
