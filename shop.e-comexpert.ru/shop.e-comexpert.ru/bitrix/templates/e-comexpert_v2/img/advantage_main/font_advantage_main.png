<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1300 320" preserveAspectRatio="xMidYMid slice">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" style="stop-color:#1a2340;stop-opacity:1"/>
      <stop offset="100%" style="stop-color:#2b3a6b;stop-opacity:1"/>
    </linearGradient>
  </defs>
  <rect width="1300" height="320" fill="url(#bg)"/>
  <!-- Decorative circles -->
  <circle cx="950" cy="160" r="280" fill="rgba(255,255,255,0.03)"/>
  <circle cx="1100" cy="80" r="140" fill="rgba(232,77,77,0.08)"/>
  <circle cx="200" cy="280" r="100" fill="rgba(255,255,255,0.02)"/>
</svg>
